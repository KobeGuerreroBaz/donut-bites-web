</style>

<script>
  // Mobile menu
  const ham = document.getElementById('hamburger');
  const menu = document.getElementById('mobileMenu');
  ham?.addEventListener('click', () => menu?.classList.toggle('open'));

  // Close menu on link click
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => menu.classList.remove('open'));
  });

  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.flavor-card, .step, .occasion-chip').forEach(el => {
    (el as HTMLElement).style.opacity = '0';
    (el as HTMLElement).style.transform = 'translateY(30px)';
    (el as HTMLElement).style.transition = 'opacity .6s ease, transform .6s ease';
    observer.observe(el);
  });
  // Lightbox Día de las Madres
    document.getElementById('thumb-0')?.addEventListener('click', () => openLightbox(0));
  document.getElementById('thumb-1')?.addEventListener('click', () => openLightbox(1));
  document.getElementById('lb-close')?.addEventListener('click', () => closeLightbox());
  document.getElementById('lb-prev')?.addEventListener('click', () => navigate(-1));
  document.getElementById('lb-next')?.addEventListener('click', () => navigate(1));
  document.getElementById('lb-dot-0')?.addEventListener('click', () => goTo(0));
  document.getElementById('lb-dot-1')?.addEventListener('click', () => goTo(1));

  const photos = [
    "/images/donas-decoradas-monterrey/donas-decoradas-dia-de-las-madres.jpg",
    "/images/donas-decoradas-monterrey/donas-decoradas-10-de-mayo.jpg",
  ];
  let current = 0;

  function openLightbox(index) {

    current = index;
    renderLb();
    document.getElementById('lb-overlay')!.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    document.getElementById('lb-overlay')!.classList.remove('open');
    document.body.style.overflow = '';
  }
  function handleOverlay(e) {

    if (e.target === document.getElementById('lb-overlay')) closeLightbox();
  }
  function navigate(dir) {
    current = (current + dir + photos.length) % photos.length;
    renderLb();
  }
  function goTo(index) {
    current = index;
    renderLb();
  }
  function renderLb() {
    (document.getElementById('lb-img') as HTMLImageElement).src = photos[current];
    document.querySelectorAll('.lb-dot').forEach((d, i) => {
      d.classList.toggle('active', i === current);
    });
  }
  document.addEventListener('keydown', (e) => {
    if (!document.getElementById('lb-overlay')!.classList.contains('open')) return;
    if (e.key === 'ArrowRight') navigate(1);
    if (e.key === 'ArrowLeft')  navigate(-1);
    if (e.key === 'Escape')     closeLightbox();
  });


</script>
  