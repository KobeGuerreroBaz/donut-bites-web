<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --pink:      #E8496A;
    --pink-lt:   #F9B8C7;
    --pink-pale: #FFF0F3;
    --choco:     #3D1A0E;
    --choco-mid: #7B3F00;
    --cream:     #FFF8F0;
    --gold:      #F4A629;
    --gold-lt:   #FFE4B0;
    --white:     #FFFFFF;
    --gray:      #6B6B6B;
    --gray-lt:   #F5F5F5;

    --ff-display: 'Fraunces', Georgia, serif;
    --ff-body:    'Nunito', system-ui, sans-serif;

    --r-sm:  8px;
    --r-md:  16px;
    --r-lg:  24px;
    --r-xl:  48px;
    --r-full: 999px;

    --shadow-sm: 0 2px 8px rgba(61,26,14,.08);
    --shadow-md: 0 8px 32px rgba(61,26,14,.12);
    --shadow-lg: 0 20px 60px rgba(61,26,14,.18);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--ff-body);
    background: var(--cream);
    color: var(--choco);
    line-height: 1.6;
    overflow-x: hidden;
  }

  .site-wrapper { position: relative; }
  .container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }

  /* ---- HEADER ---- */
  .header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(255,248,240,.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--pink-lt);
  }
  .nav {
    display: flex; align-items: center; justify-content: space-between;
    max-width: 1120px; margin: 0 auto; padding: 16px 24px;
  }
  .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; color: inherit; }
  .logo-icon { font-size: 2rem; line-height: 1; }
  .logo-text { font-family: var(--ff-display); font-size: 1.4rem; font-weight: 400; color: var(--choco); }
  .logo-text strong { color: var(--pink); }
  .logo-co { color: var(--gold); }

  .nav-links { display: flex; align-items: center; gap: 28px; }
  .nav-links a { text-decoration: none; color: var(--choco); font-weight: 600; font-size: .95rem; transition: color .2s; }
  .nav-links a:hover { color: var(--pink); }

  .btn-nav-wapp {
    display: flex; align-items: center; gap: 7px;
    background: #25D366; color: var(--white) !important;
    padding: 10px 18px; border-radius: var(--r-full);
    font-weight: 700; font-size: .9rem;
    box-shadow: 0 4px 14px rgba(37,211,102,.35);
    transition: transform .2s, box-shadow .2s;
  }
  .btn-nav-wapp:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(37,211,102,.45); }

  .hamburger {
    display: none; flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer; padding: 4px;
  }
  .hamburger span { display: block; width: 24px; height: 2px; background: var(--choco); border-radius: 2px; transition: .3s; }

  .mobile-menu {
    display: none; flex-direction: column;
    padding: 16px 24px 20px;
    border-top: 1px solid var(--pink-lt);
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a {
    padding: 12px 0; text-decoration: none; color: var(--choco);
    font-weight: 700; font-size: 1.05rem; border-bottom: 1px solid var(--pink-pale);
  }
  .mobile-menu a:last-child { border-bottom: none; color: #25D366; }

  /* ---- HERO ---- */
  .hero {
    position: relative; overflow: hidden;
    min-height: 90vh;
    display: grid; grid-template-columns: 1fr 1fr; align-items: center;
    gap: 40px; padding: 80px 60px 80px 80px;
    background: linear-gradient(135deg, #FFF0F3 0%, #FFF8F0 50%, #FFF3E8 100%);
  }

  .hero-bg { position: absolute; inset: 0; pointer-events: none; z-index: 0; }
  .blob {
    position: absolute; border-radius: 50%;
    filter: blur(80px); opacity: .35;
    animation: blobFloat 8s ease-in-out infinite;
  }
  .blob-1 { width: 500px; height: 500px; background: var(--pink-lt); top: -200px; right: -100px; animation-delay: 0s; }
  .blob-2 { width: 350px; height: 350px; background: var(--gold-lt); bottom: -100px; left: 100px; animation-delay: 3s; }
  .blob-3 { width: 250px; height: 250px; background: #FFD6E7; top: 50%; right: 300px; animation-delay: 5s; }

  @keyframes blobFloat {
    0%, 100% { transform: translate(0,0) scale(1); }
    50% { transform: translate(20px, -30px) scale(1.05); }
  }

  .sprinkle-field {
    position: absolute; inset: 0;
    display: flex; flex-wrap: wrap;
    align-items: center; justify-content: space-around;
    opacity: .08; font-size: 3rem;
  }
  .s { animation: spinFloat 12s ease-in-out infinite; }
  .s:nth-child(2) { animation-delay: 1.5s; }
  .s:nth-child(3) { animation-delay: 3s; }
  .s:nth-child(4) { animation-delay: 4.5s; }
  .s:nth-child(5) { animation-delay: 6s; }
  .s:nth-child(6) { animation-delay: 7.5s; }
  .s:nth-child(7) { animation-delay: 9s; }
  .s:nth-child(8) { animation-delay: 10.5s; }

  @keyframes spinFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(180deg); }
  }

  .hero-content { position: relative; z-index: 1; animation: fadeUp .8s ease both; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--white); border: 1.5px solid var(--pink-lt);
    color: var(--pink); font-weight: 700; font-size: .85rem;
    padding: 8px 16px; border-radius: var(--r-full);
    margin-bottom: 24px;
    box-shadow: var(--shadow-sm);
  }

  .hero-title {
    font-family: var(--ff-display);
    font-size: clamp(2.8rem, 5vw, 4.2rem);
    font-weight: 900; line-height: 1.1;
    color: var(--choco); margin-bottom: 20px;
  }
  .hero-title em {
    font-style: italic; color: var(--pink);
    background: linear-gradient(135deg, var(--pink), #F4736A);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.15rem; color: var(--gray);
    max-width: 480px; margin-bottom: 36px; line-height: 1.7;
  }

  .hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 48px; }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 10px;
    background: linear-gradient(135deg, #25D366, #1DA851);
    color: var(--white); font-weight: 800; font-size: 1rem;
    padding: 16px 28px; border-radius: var(--r-full);
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(37,211,102,.4);
    transition: transform .25s, box-shadow .25s;
  }
  .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 14px 32px rgba(37,211,102,.5); }
  .btn-primary.large { font-size: 1.1rem; padding: 18px 36px; }

  .btn-secondary {
    display: inline-flex; align-items: center; gap: 8px;
    border: 2px solid var(--pink); color: var(--pink);
    font-weight: 700; font-size: 1rem;
    padding: 14px 24px; border-radius: var(--r-full);
    text-decoration: none;
    transition: background .2s, color .2s;
  }
  .btn-secondary:hover { background: var(--pink); color: var(--white); }

  .hero-stats {
    display: flex; align-items: center; gap: 24px;
    padding: 20px 28px; background: var(--white);
    border-radius: var(--r-lg); box-shadow: var(--shadow-md);
    width: fit-content;
  }
  .stat { text-align: center; }
  .stat strong { display: block; font-family: var(--ff-display); font-size: 1.4rem; font-weight: 900; color: var(--pink); }
  .stat span { font-size: .8rem; color: var(--gray); font-weight: 600; }
  .stat-divider { width: 1px; height: 40px; background: var(--pink-lt); }

  /* HERO VISUAL */
  .hero-visual {
    position: relative; z-index: 1;
    display: flex; justify-content: center; align-items: center;
    animation: fadeUp .8s .3s ease both;
  }

  .donut-showcase { position: relative; width: 360px; height: 360px; }

  .donut-ring {
    position: absolute; border-radius: 50%;
    animation: spin 20s linear infinite;
  }
  .donut-ring-outer {
    inset: 0; border: 3px dashed var(--pink-lt);
  }
  .donut-ring-mid {
    inset: 40px; border: 2px dashed var(--gold-lt);
    animation-direction: reverse; animation-duration: 15s;
  }
  @keyframes spin { from { transform: rotate(0); } to { transform: rotate(360deg); } }

  .donut-emoji-main {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    font-size: 9rem; line-height: 1;
    animation: bounce 3s ease-in-out infinite;
    filter: drop-shadow(0 20px 30px rgba(232,73,106,.3));
  }
  @keyframes bounce {
    0%, 100% { transform: translate(-50%,-50%) rotate(-5deg) scale(1); }
    50% { transform: translate(-50%,-56%) rotate(5deg) scale(1.05); }
  }

  .floating-tag {
    position: absolute;
    background: var(--white); border-radius: var(--r-full);
    padding: 10px 18px; font-weight: 800; font-size: .85rem;
    box-shadow: var(--shadow-md); color: var(--choco);
    animation: floatTag 4s ease-in-out infinite;
  }
  .tag-1 { top: 30px; right: -20px; animation-delay: 0s; }
  .tag-2 { bottom: 60px; left: -30px; animation-delay: 2s; }
  @keyframes floatTag {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  /* ---- SECTIONS COMMON ---- */
  .section-header { text-align: center; margin-bottom: 56px; }
  .section-eyebrow {
    display: inline-block;
    background: var(--pink-pale); color: var(--pink);
    font-weight: 800; font-size: .8rem; letter-spacing: .1em; text-transform: uppercase;
    padding: 6px 16px; border-radius: var(--r-full); margin-bottom: 16px;
  }
  .section-header h2 {
    font-family: var(--ff-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900; color: var(--choco);
    margin-bottom: 16px; line-height: 1.2;
  }
  .section-header p { font-size: 1.1rem; color: var(--gray); max-width: 560px; margin: 0 auto; }
  .section-header.light h2 { color: var(--white); }
  .section-header.light p { color: rgba(255,255,255,.8); }
  .section-header.light .section-eyebrow { background: rgba(255,255,255,.2); color: var(--white); }

  /* ---- FLAVORS ---- */
  .section-flavors { padding: 100px 0; background: var(--cream); }

  .flavors-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
    margin-bottom: 56px;
  }

  .flavor-card {
    background: var(--white); border-radius: var(--r-lg);
    padding: 36px 28px; text-align: center;
    border: 1.5px solid transparent;
    box-shadow: var(--shadow-sm);
    transition: transform .3s, box-shadow .3s, border-color .3s;
    cursor: default;
  }
  .flavor-card:hover {
    transform: translateY(-8px); box-shadow: var(--shadow-lg);
    border-color: var(--pink-lt);
  }
  .flavor-emoji { font-size: 3.5rem; margin-bottom: 16px; display: block; }
.flavor-img { width: 100%; height: 200px; object-fit: cover; border-radius: 12px; margin-bottom: 16px; display: block; }
  .flavor-card h3 {
    font-family: var(--ff-display); font-size: 1.2rem; font-weight: 700;
    color: var(--choco); margin-bottom: 10px;
  }
  .flavor-card p { font-size: .95rem; color: var(--gray); line-height: 1.5; }

  .flavors-cta { text-align: center; }
  .flavors-cta p { font-size: 1.1rem; color: var(--gray); margin-bottom: 20px; }

  /* ---- OCCASIONS ---- */
  .section-occasions {
    padding: 100px 0;
    background: linear-gradient(135deg, var(--choco) 0%, #5C2A10 100%);
    position: relative; overflow: hidden;
  }
  .section-occasions::before {
    content: '🍩';
    position: absolute; font-size: 20rem; opacity: .04;
    right: -4rem; top: 50%; transform: translateY(-50%);
    pointer-events: none;
  }

  .occasions-grid {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 16px;
    margin-bottom: 48px;
  }
  .occasion-chip {
    display: flex; align-items: center; gap: 10px;
    background: rgba(255,255,255,.1); border: 1.5px solid rgba(255,255,255,.2);
    color: var(--white); font-weight: 700; font-size: .95rem;
    padding: 12px 22px; border-radius: var(--r-full);
    backdrop-filter: blur(8px);
    transition: background .2s, transform .2s;
  }
  .occasion-chip:hover { background: rgba(255,255,255,.2); transform: scale(1.05); }
  .occ-icon { font-size: 1.4rem; }

  .occasions-note { display: flex; justify-content: center; }
  .note-card {
    background: rgba(255,255,255,.1); border: 1.5px solid rgba(255,255,255,.2);
    border-radius: var(--r-lg); padding: 28px 36px;
    backdrop-filter: blur(12px); max-width: 600px; text-align: center;
    color: var(--white);
  }
  .note-card p { font-size: 1rem; line-height: 1.6; margin-bottom: 20px; }

  .social-links { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; }
  .social-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: var(--r-full);
    font-weight: 700; font-size: .9rem; text-decoration: none;
    transition: transform .2s, opacity .2s;
  }
  .social-btn:hover { transform: translateY(-2px); opacity: .9; }
  .social-btn.instagram { background: linear-gradient(135deg, #E1306C, #833AB4); color: var(--white); }
  .social-btn.tiktok    { background: var(--choco); color: var(--white); }
  .social-btn.facebook  { background: #1877F2; color: var(--white); }

  /* ---- PROCESS ---- */
  .section-process {
    padding: 100px 0;
    background: var(--pink-pale);
  }
  .process-steps {
    display: flex; align-items: center; justify-content: center;
    gap: 16px; flex-wrap: wrap; margin-bottom: 56px;
  }
  .step {
    background: var(--white); border-radius: var(--r-lg);
    padding: 40px 32px; text-align: center;
    flex: 1; min-width: 220px; max-width: 280px;
    box-shadow: var(--shadow-md);
    position: relative; overflow: hidden;
  }
  .step::before {
    content: ''; position: absolute;
    top: 0; left: 0; right: 0; height: 4px;
    background: linear-gradient(90deg, var(--pink), var(--gold));
  }
  .step-num {
    position: absolute; top: 16px; right: 20px;
    font-family: var(--ff-display); font-size: 3rem; font-weight: 900;
    color: var(--pink-pale); line-height: 1;
  }
  .step-icon { font-size: 3rem; margin-bottom: 16px; display: block; }
  .step h3 { font-family: var(--ff-display); font-size: 1.2rem; font-weight: 700; color: var(--choco); margin-bottom: 10px; }
  .step p { font-size: .95rem; color: var(--gray); }

  .step-arrow { font-size: 1.8rem; color: var(--pink-lt); flex-shrink: 0; }
  .process-cta { text-align: center; }

  /* ---- ABOUT ---- */
  .section-about { padding: 100px 0; background: var(--cream); }
  .about-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: center;
  }
  .about-visual { display: flex; justify-content: center; }
  .about-donut-wrap { position: relative; width: 300px; height: 300px; }
  .about-emoji {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 8rem;
    animation: bounce 4s ease-in-out infinite;
    filter: drop-shadow(0 20px 30px rgba(232,73,106,.25));
  }
  .about-bubble {
    position: absolute; background: var(--white);
    border-radius: var(--r-full); padding: 10px 18px;
    font-weight: 700; font-size: .85rem; color: var(--choco);
    box-shadow: var(--shadow-md);
    animation: floatTag 4s ease-in-out infinite;
  }
  .b1 { top: 10px; right: -40px; animation-delay: 0s; }
  .b2 { bottom: 30px; left: -30px; animation-delay: 2s; }

  .about-text .section-eyebrow { display: inline-block; margin-bottom: 16px; }
  .about-text h2 {
    font-family: var(--ff-display); font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 900; color: var(--choco); margin-bottom: 20px; line-height: 1.2;
  }
  .about-text p { font-size: 1rem; color: var(--gray); margin-bottom: 16px; line-height: 1.7; }

  .about-badges { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px; }
  .badge {
    background: var(--pink-pale); color: var(--pink);
    border: 1.5px solid var(--pink-lt);
    border-radius: var(--r-full); padding: 8px 18px;
    font-weight: 700; font-size: .9rem;
  }

  /* ---- STICKY WHATSAPP ---- */
  .wapp-sticky {
    position: fixed; bottom: 28px; right: 28px; z-index: 200;
    display: flex; align-items: center; gap: 10px;
    background: #25D366; color: var(--white);
    padding: 14px 22px; border-radius: var(--r-full);
    font-weight: 800; font-size: .95rem; text-decoration: none;
    box-shadow: 0 8px 32px rgba(37,211,102,.5);
    animation: pulse 2.5s ease-in-out infinite;
    transition: transform .2s;
  }
  .wapp-sticky:hover { transform: scale(1.05); animation: none; }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 8px 32px rgba(37,211,102,.5); }
    50% { box-shadow: 0 8px 48px rgba(37,211,102,.75), 0 0 0 8px rgba(37,211,102,.15); }
  }

  /* ---- FOOTER ---- */
  .footer {
    background: var(--choco); color: rgba(255,255,255,.7);
    padding: 48px 0;
  }
  .footer-inner { text-align: center; }
  .footer-logo {
    display: inline-flex; align-items: center; gap: 10px;
    font-family: var(--ff-display); font-size: 1.4rem;
    color: var(--white); margin-bottom: 12px;
  }
  .footer-logo strong { color: var(--pink); }
  .footer-tagline { font-size: .9rem; margin-bottom: 24px; }

  .footer-socials { display: flex; justify-content: center; gap: 20px; margin-bottom: 24px; }
  .footer-socials a {
    color: rgba(255,255,255,.6); transition: color .2s, transform .2s;
    display: flex;
  }
  .footer-socials a:hover { color: var(--white); transform: translateY(-2px); }
