---
import Layout from '../layouts/Layout.astro';

const whatsappNumber = "528146812034"; // Reemplazar con el número real
const whatsappMessage = encodeURIComponent("¡Hola! Vi su página y me gustaría hacer un pedido de donas 🍩");
const whatsappURL = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;

const flavors = [
  { img: "/images/donas-decoradas-monterrey/caja-de-donas-decoradas.jpeg", name: "Caja de Donas", desc: "Selección de donas decoradas artesanales" },
  { img: "/images/donas-decoradas-monterrey/donas-decoradas-halloween.jpeg", name: "Donas Halloween", desc: "Diseños exclusivos de temporada para Halloween" },
  { emoji: "🍋", name: "Limón Merengue", desc: "Glaseado amarillo con toque cítrico y merengue" },
  { emoji: "🌸", name: "Vainilla Floral", desc: "Clásica con decoración floral artesanal" },
  { emoji: "🎉", name: "Temporada Especial", desc: "Diseños exclusivos que cambian según la ocasión" },
  { emoji: "✨", name: "Personalizada", desc: "Cuéntanos tu idea y la hacemos realidad" },
];

const occasions = [
  { icon: "🎂", label: "Cumpleaños" },
  { icon: "💍", label: "Boda" },
  { icon: "🎄", label: "Navidad" },
  { icon: "💝", label: "San Valentín" },
  { icon: "🐣", label: "Pascua" },
  { icon: "🎓", label: "Graduación" },
  { icon: "👶", label: "Baby Shower" },
  { icon: "🎃", label: "Halloween" },
];
---

<Layout>
  <div class="site-wrapper">

    <!-- ===== HEADER ===== -->
    <header class="header">
      <nav class="nav">
        <div class="logo">
          <span class="logo-icon">🍩</span>
          <span class="logo-text">Donut<strong>Bites</strong><span class="logo-co">.co</span></span>
        </div>
        <div class="nav-links">
          <a href="#sabores">Sabores</a>
          <a href="#ocasiones">Ocasiones</a>
          <a href="#nosotros">Nosotros</a>
          <a href={whatsappURL} class="btn-nav-wapp" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Pedir ahora
          </a>
        </div>
        <button class="hamburger" id="hamburger" aria-label="Menú">
          <span></span><span></span><span></span>
        </button>
      </nav>
      <div class="mobile-menu" id="mobileMenu">
        <a href="#sabores">Sabores</a>
        <a href="#ocasiones">Ocasiones</a>
        <a href="#nosotros">Nosotros</a>
        <a href={whatsappURL} target="_blank" rel="noopener">💬 Hacer pedido</a>
      </div>
    </header>
<!-- ===== BANNER DÍA DE LAS MADRES ===== -->
<section class="banner-madres">
  <div class="petal">🌸</div>
  <div class="petal">🌹</div>
  <div class="petal">🌷</div>
  <div class="petal">💐</div>
  <div class="petal">🌺</div>
  <div class="petal">🌸</div>

  <div class="banner-madres-tag">💐 Edición especial · 10 de mayo</div>
  <h2 class="banner-madres-title">Para la mamá más <em>dulce</em></h2>
  <p class="banner-madres-sub">Donas decoradas artesanalmente para celebrar su día como se merece</p>

  <div class="banner-madres-gallery">
    <div class="madres-thumb" id="thumb-0">
      <img src="/images/donas-decoradas-monterrey/donas-decoradas-dia-de-las-madres.jpg" alt="Dona decorada Día de las Madres Monterrey" />
      <div class="madres-overlay"><span>Ver foto</span></div>
    </div>
    <div class="madres-thumb" id="thumb-1">
      <img src="/images/donas-decoradas-monterrey/donas-decoradas-10-de-mayo.jpg" alt="Dona especial para mamá Monterrey" />
      <div class="madres-overlay"><span>Ver foto</span></div>
    </div>
  </div>

  <a href={whatsappURL} class="banner-madres-cta" target="_blank" rel="noopener">
    💬 Hacer pedido por WhatsApp
  </a>
</section>

<!-- LIGHTBOX -->
<div class="lb-overlay" id="lb-overlay" onclick="handleOverlay(event)">
  <div class="lb-inner">
    <button class="lb-close" id="lb-close">✕</button>
<button class="lb-prev" id="lb-prev">‹</button>
<button class="lb-next" id="lb-next">›</button>
    <img id="lb-img" src="" alt="" class="lb-img" />
    <div class="lb-dots">
      <button class="lb-dot active" id="lb-dot-0"></button>
<button class="lb-dot" id="lb-dot-1"></button>
    </div>
  </div>
</div>

    <!-- ===== HERO ===== -->
    <section class="hero" id="inicio">
      <div class="hero-bg">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
        <div class="sprinkle-field" aria-hidden="true">
          <span class="s">🍩</span><span class="s">✨</span><span class="s">🌸</span>
          <span class="s">⭐</span><span class="s">🍩</span><span class="s">💫</span>
          <span class="s">🌟</span><span class="s">🍩</span>
        </div>
      </div>
      <div class="hero-content">
        <div class="hero-badge">📍 Monterrey &amp; Área Metropolitana</div>
        <h1 class="hero-title">
          Donas decoradas<br />
          <em>hechas con amor</em>
        </h1>
        <p class="hero-subtitle">
          Diseños únicos y artesanales que cambian con cada temporada.
          Perfectas para cualquier ocasión especial. Solo por encargo.
        </p>
        <div class="hero-ctas">
          <a href={whatsappURL} class="btn-primary" target="_blank" rel="noopener">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Hacer mi pedido
          </a>
          <a href="#sabores" class="btn-secondary">Ver sabores ↓</a>
        </div>
        <div class="hero-stats">
          <div class="stat"><strong>100%</strong><span>Artesanal</span></div>
          <div class="stat-divider"></div>
          <div class="stat"><strong>MTY</strong><span>y Área Metro</span></div>
          <div class="stat-divider"></div>
          <div class="stat"><strong>🍩</strong><span>Por encargo</span></div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="donut-showcase">
          <div class="donut-ring donut-ring-outer"></div>
          <div class="donut-ring donut-ring-mid"></div>
          <div class="donut-emoji-main">🍩</div>
          <div class="floating-tag tag-1">¡Personalizadas!</div>
          <div class="floating-tag tag-2">Entrega en MTY 🛵</div>
        </div>
      </div>
    </section>

    <!-- ===== SABORES ===== -->
    <section class="section-flavors" id="sabores">
      <div class="container">
        <div class="section-header">
          <span class="section-eyebrow">Nuestros Sabores</span>
          <h2>Cada dona, una obra de arte</h2>
          <p>Ingredientes de calidad, decoración artesanal y mucho cariño en cada pieza.</p>
        </div>
        <div class="flavors-grid">
          {flavors.map((f) => (
            <div class="flavor-card">
              {f.img ? <img src={f.img} alt={f.name} class="flavor-img" /> : <div class="flavor-emoji">{f.emoji}</div>}
              <h3>{f.name}</h3>
              <p>{f.desc}</p>
            </div>
          ))}
        </div>
        <div class="flavors-cta">
          <p>¿Tienes un sabor o diseño en mente?</p>
          <a href={whatsappURL} class="btn-primary" target="_blank" rel="noopener">Cuéntanos por WhatsApp</a>
        </div>
      </div>
    </section>

    <!-- ===== OCASIONES ===== -->
    <section class="section-occasions" id="ocasiones">
      <div class="container">
        <div class="section-header light">
          <span class="section-eyebrow">Para cada momento</span>
          <h2>La dona perfecta para cada ocasión</h2>
          <p>Nuestros diseños de temporada se adaptan a lo que necesitas celebrar.</p>
        </div>
        <div class="occasions-grid">
          {occasions.map((o) => (
            <div class="occasion-chip">
              <span class="occ-icon">{o.icon}</span>
              <span>{o.label}</span>
            </div>
          ))}
        </div>
        <div class="occasions-note">
          <div class="note-card">
            <p>🌟 <strong>Diseños de temporada</strong> — Nuestro catálogo se renueva con cada fecha especial del año. Síguenos en redes para ver los diseños más recientes.</p>
            <div class="social-links">
              <a href="https://www.instagram.com/donut.bites.co" target="_blank" rel="noopener" class="social-btn instagram">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                Instagram
              </a>
              <a href="https://www.tiktok.com/@donut.bites85" target="_blank" rel="noopener" class="social-btn tiktok">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V9.05a8.26 8.26 0 004.84 1.55V7.15a4.85 4.85 0 01-1.07-.46z"/></svg>
                TikTok
              </a>
              <a href="https://www.facebook.com/donutbitesco" target="_blank" rel="noopener" class="social-btn facebook">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                Facebook
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PROCESO ===== -->
    <section class="section-process">
      <div class="container">
        <div class="section-header">
          <span class="section-eyebrow">¿Cómo pedir?</span>
          <h2>Tu pedido en 3 pasos</h2>
        </div>
        <div class="process-steps">
          <div class="step">
            <div class="step-num">1</div>
            <div class="step-icon">💬</div>
            <h3>Escríbenos</h3>
            <p>Contáctanos por WhatsApp con tu idea, cantidad y fecha de entrega.</p>
          </div>
          <div class="step-arrow">→</div>
          <div class="step">
            <div class="step-num">2</div>
            <div class="step-icon">🎨</div>
            <h3>Diseñamos</h3>
            <p>Creamos el diseño perfecto para tu ocasión. ¡Tú decides los detalles!</p>
          </div>
          <div class="step-arrow">→</div>
          <div class="step">
            <div class="step-num">3</div>
            <div class="step-icon">🍩</div>
            <h3>¡Disfruta!</h3>
            <p>Recibe tus donas frescas y listas para sorprender a todos.</p>
          </div>
        </div>
        <div class="process-cta">
          <a href={whatsappURL} class="btn-primary large" target="_blank" rel="noopener">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Iniciar mi pedido ahora
          </a>
        </div>
      </div>
    </section>

    <!-- ===== NOSOTROS ===== -->
    <section class="section-about" id="nosotros">
      <div class="container about-grid">
        <div class="about-visual">
          <div class="about-donut-wrap">
            <div class="about-emoji">🍩</div>
            <div class="about-bubble b1">Hecho con amor ❤️</div>
            <div class="about-bubble b2">100% artesanal ✨</div>
          </div>
        </div>
        <div class="about-text">
          <span class="section-eyebrow">Nuestra historia</span>
          <h2>Donas que cuentan una historia</h2>
          <p>Somos un emprendimiento familiar en Monterrey. Cada dona es elaborada a mano con ingredientes cuidadosamente seleccionados y decorada con la atención al detalle que solo el amor puede dar.</p>
          <p>Nuestros diseños cambian con las temporadas, porque creemos que cada celebración merece algo especial y único. Desde cumpleaños hasta navidad, tenemos la dona perfecta para ti.</p>
          <div class="about-badges">
            <div class="badge">🏠 Negocio familiar</div>
            <div class="badge">🎨 Diseño artesanal</div>
            <div class="badge">📍 Monterrey y AMM</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== STICKY WHATSAPP ===== -->
    <a href={whatsappURL} class="wapp-sticky" target="_blank" rel="noopener" aria-label="Contactar por WhatsApp">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      <span>Pedir ahora</span>
    </a>

    <!-- ===== FOOTER ===== -->
    <footer class="footer">
      <div class="container footer-inner">
        <div class="footer-logo">
          <span>🍩</span>
          <span>Donut<strong>Bites</strong>.co</span>
        </div>
        <p class="footer-tagline">Donas decoradas artesanales · Monterrey y Área Metropolitana</p>
        <div class="footer-socials">
          <a href="https://www.instagram.com/donut.bites.co" target="_blank" rel="noopener" aria-label="Instagram">
