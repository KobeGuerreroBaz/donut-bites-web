---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Donut Bites.co | Donas Decoradas en Monterrey y Área Metropolitana",
  description = "Donas decoradas artesanales en Monterrey y toda el Área Metropolitana. Diseños únicos por temporada, hechas con amor para cada ocasión especial. Pedidos por WhatsApp.",
  image = "/og-image.jpg",
} = Astro.props;

const siteUrl = "https://www.donutbites.co";
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

const schema = {
  "@context": "https://schema.org",
  "@type": "Bakery",
  "name": "Donut Bites.co",
  "description": description,
  "url": siteUrl,
  "areaServed": [
    "Monterrey", "San Pedro Garza García", "San Nicolás de los Garza",
    "Guadalupe", "Apodaca", "Escobedo", "Santa Catarina", "Juárez"
  ],
  "address": {
    "@type": "PostalAddress",
    "addressRegion": "Nuevo León",
    "addressCountry": "MX",
    "addressLocality": "Monterrey"
  },
  "servesCuisine": "Donas decoradas artesanales",
  "sameAs": [
    "https://www.facebook.com/donutbitesco",
    "https://www.instagram.com/donutbitesco",
    "https://www.tiktok.com/@donutbitesco"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "availableLanguage": "Spanish"
  }
};
---

<!DOCTYPE html>
<html lang="es-MX">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#E8496A" />
  <link rel="canonical" href={canonicalURL} />

  <!-- SEO Primary -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="donas decoradas Monterrey, donas artesanales Monterrey, donas personalizadas MTY, donas por encargo Monterrey, repostería Monterrey, donas Área Metropolitana" />
  <meta name="author" content="Donut Bites.co" />
  <meta name="robots" content="index, follow" />
  <meta name="geo.region" content="MX-NL" />
  <meta name="geo.placename" content="Monterrey, Nuevo León" />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}${image}`} />
  <meta property="og:locale" content="es_MX" />
  <meta property="og:site_name" content="Donut Bites.co" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}${image}`} />

  <!-- Preconnect fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;0,9..144,900;1,9..144,400&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />

  <!-- Schema.org Local Business -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</head>
<body>
  <slot />
</body>
</html>
